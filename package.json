{
  "name": "avilaDS-storybook-tokens",
  "version": "1.0.0",
  "description": "Design token pipeline for AvilaDS — transforms raw tokens into CSS, JS/TS, and SCSS outputs",
  "main": "dist/index.js",
  "scripts": {
    "build:tokens": "node scripts/build-tokens.js",
    "watch:tokens": "node scripts/build-tokens.js --watch",
    "snapshot": "node scripts/snapshot.js",
    "diff:tokens": "node scripts/diff.js",
    "sync:tokens": "node scripts/sync-tokens.js",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static"
  },
  "keywords": [
    "design-tokens",
    "style-dictionary",
    "design-system"
  ],
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@vitejs/plugin-react": "^6.0.1",
    "prop-types": "^15.8.1",
    "storybook": "^8.6.18",
    "style-dictionary": "^5.4.0",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@radix-ui/react-primitive": "^2.1.4",
    "@radix-ui/react-slot": "^1.2.4"
  }
}
